# ─── 카카오 ─────────────────────────────────────────────────────────────────
# Kakao Developers (https://developers.kakao.com) → 내 앱 → 앱 키 → REST API 키
KAKAO_MOBILITY_REST_KEY=

# ─── TMAP ───────────────────────────────────────────────────────────────────
# T Developers (https://openapi.sk.com) → 마이페이지 → 앱 관리 → 앱 키
TMAP_APP_KEY=

# ─── 공공데이터포털 — 경기도 버스 + TAGO 지하철 ────────────────────────────
# 공공데이터포털 (https://www.data.go.kr) → 마이페이지 → Open API → 인증키
# 버스도착정보, 버스위치정보, TAGO 지하철정보 모두 동일 키 사용
# 각 API별로 활용 신청은 별도로 필요
DATA_GO_KR_SERVICE_KEY=

# ─── 기상청 단기예보 OpenAPI ─────────────────────────────────────────────────
# 공공데이터포털 (https://www.data.go.kr) → 기상청_단기예보_((구)_동네예보)_조회서비스 활용 신청
KMA_API_KEY=your_key_here

# ─── 데이터베이스 ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transit_hub
DB_USER=
DB_PASSWORD=
# Docker postgres 컨테이너용 (위 DB_* 와 동일 값으로 유지)
POSTGRES_DB=transit_hub
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── 관리자 인증 (JWT) ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# bcrypt 해시 값 (평문 절대 입력 금지)
# 생성: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PW', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=CHANGE_ME_bcrypt_hash
# 생성: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── 앱 설정 ────────────────────────────────────────────────────────────────
ENVIRONMENT=development       # development | production
ALLOWED_ORIGINS=http://localhost:5173

# ─── 모니터링 도구 (개발용, 프로덕션에서는 강력한 비밀번호 사용) ──────────────
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_strong_password
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_strong_password
# /metrics 엔드포인트 Bearer 토큰 (생성: openssl rand -hex 32)
METRICS_TOKEN=CHANGE_ME_openssl_rand_hex_32
